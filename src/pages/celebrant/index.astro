---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import CelebrantNav from '../../components/CelebrantNav.astro';
import CelebrantFooter from '../../components/CelebrantFooter.astro';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService"],
  "name": "Tom Allen — Marriage Celebrant",
  "description": "Wedding ceremonies that feel like you. Darwin-based Authorised Marriage Celebrant serving the Northern Territory and Australia-wide.",
  "url": "https://tomallen.com.au/celebrant/",
  "telephone": "+61421102154",
  "email": "allen.tom.c@gmail.com",
  "image": "https://tomallen.com.au/images/celebrant/hero.jpg",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Darwin",
    "addressRegion": "Northern Territory",
    "addressCountry": "AU"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -12.4634,
    "longitude": 130.8456
  },
  "areaServed": [
    { "@type": "City", "name": "Darwin" },
    { "@type": "AdministrativeArea", "name": "Northern Territory" },
    { "@type": "Country", "name": "Australia" }
  ],
  "priceRange": "$$",
  "hasCredential": {
    "@type": "EducationalOccupationalCredential",
    "credentialCategory": "Certificate IV in Celebrancy",
    "recognizedBy": {
      "@type": "Organization",
      "name": "Attorney-General's Department of Australia"
    }
  },
  "knowsAbout": ["wedding ceremonies", "marriage ceremonies", "same-sex weddings", "civil ceremonies", "elopements"]
};
---

<BaseLayout title="Tom Allen — Marriage Celebrant, Darwin NT" description="Wedding ceremonies that feel like you. Marriage celebrant based in Darwin, Northern Territory." section="celebrant">
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <Nav section="celebrant" />
  <CelebrantNav activePage="home" />

  <main style="padding-top: 96px;">
    <!-- Hero -->
    <section class="cel-hero">
      <img src="/images/celebrant/hero.jpg" alt="Wedding ceremony" class="cel-hero__img" onerror="this.style.display='none'" />
      <div class="cel-hero__overlay">
        <div class="cel-hero__content">
          <p class="fade-in label" style="color: #FFFFFF; margin-bottom: 16px; opacity: 0.8;">Marriage Celebrant — Darwin, NT</p>
          <h1 class="fade-in cel-hero__title" data-delay="200">Ceremonies that<br />feel like you</h1>
        </div>
      </div>
    </section>

    <!-- Hero Intro -->
    <section class="cel-intro">
      <div class="cel-intro__content fade-in">
        <p class="cel-intro__desc">
          The wedding ceremonies I craft are all about presence. Even despite our best efforts, our wedding days are usually a blur. The opportunity I present to you as your celebrant is not more noise, more chatter, more intensity, but a moment of pause, of presence, to see clearly where you've come from and where you're choosing to go.
        </p>
        <div class="cel-intro__actions">
          <a href="/celebrant/enquire/" class="btn" style="background: var(--cel-accent); color: #FFFFFF; font-weight: 600;">Get in Touch</a>
          <a href="/celebrant/how-i-work/" class="btn btn-outline">How I Work</a>
        </div>
      </div>
    </section>

    <!-- Three Value Props -->
    <section class="container-wide fade-in" style="padding: 80px 32px 60px;">
      <div class="cel-values">
        <div class="cel-values__item">
          <h3>A Time to Connect</h3>
          <p>Weddings are about stories, old and new. Weddings bring us together. My role as a celebrant is to help you tell your story and connect with your people authentically.</p>
        </div>
        <div class="cel-values__item">
          <h3>A Time to Celebrate</h3>
          <p>Weddings should be fun. They are opportunities for us to fill our cup, to be joyful, to share hope, and to share in the wonder and mystery of love. My job is to help you make it fun, whatever that means to you. Introverts, extroverts, big weddings or small: this is a day to remember.</p>
        </div>
        <div class="cel-values__item">
          <h3>A Day to Reflect</h3>
          <p>Life is full of challenges and mundane moments. A wedding is neither of those. It is a chance to take a deep breath and state what is most true to you, what you feel in your bones. I'm here to hold a little space for you to bring your best selves and have a moment to reflect on the preciousness of life.</p>
        </div>
      </div>
    </section>

    <!-- Photo Gallery -->
    <section class="container-full fade-in" data-delay="100" style="padding: 0 32px 80px;">
      <div class="cel-gallery">
        <div class="cel-gallery__portrait">
          <img src="/images/celebrant/gallery-5.jpg" alt="Tom Allen officiating a same-sex wedding ceremony, two grooms holding hands at an intimate indoor venue" onerror="this.parentElement.classList.add('placeholder-img','placeholder-img--warm')" />
        </div>
        <div class="cel-gallery__col">
          <div class="cel-gallery__cell">
            <img src="/images/celebrant/gallery-1.jpg" alt="Newlyweds walking back up the aisle as guests shower them with confetti at an outdoor garden wedding" onerror="this.parentElement.classList.add('placeholder-img','placeholder-img--warm')" />
          </div>
          <div class="cel-gallery__cell">
            <img src="/images/celebrant/gallery-2.jpg" alt="Tom Allen officiating an outdoor garden wedding ceremony as the groom and groomsmen smile" onerror="this.parentElement.classList.add('placeholder-img','placeholder-img--dark')" />
          </div>
        </div>
        <div class="cel-gallery__col">
          <div class="cel-gallery__cell">
            <img src="/images/celebrant/gallery-3.jpg" alt="Tom Allen and a couple celebrating after an intimate outdoor bush ceremony among Australian gum trees" onerror="this.parentElement.classList.add('placeholder-img','placeholder-img--warm')" />
          </div>
          <div class="cel-gallery__cell">
            <img src="/images/celebrant/gallery-4.jpg" alt="Tom Allen watching as a newly married couple embrace at a relaxed bohemian bush wedding ceremony" onerror="this.parentElement.classList.add('placeholder-img','placeholder-img--cool')" />
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="cel-testimonials">
      <div class="container-narrow">
        {[
          { quote: "It was Tom's first run as a celebrant and I already had other guests asking if he was available to do their wedding. He was truly a natural; eloquent, witty and personable with real attention to detail and great communication.", who: "Joe and Molly, Quamby Estate, TAS" },
          { quote: "Tom was interested and interesting, attentive and so kind! He held the most amazing space full of life and energy at our wedding and included our family including two young kids in all we did. We won't forget how much he set the scene and brought us together for our wedding day. My nanna loved him and so did my aunties.", who: "Zoe and Will, Kangaroobie, VIC" },
          { quote: "What a joy and honour it was to work with Tom to create the marriage ceremony of our dreams. Tom was instrumental in crafting the structure of our ceremony so that the magic could flow so beautifully on the day. He had such a grounding influence on us throughout the whole process, getting things organised well in advance so that we were able to 'let go' as the wedding storm swept us up.", who: "Michaela and Lachie, Stieglitz, VIC" },
        ].map((t, i) => (
          <blockquote class="fade-in cel-quote" data-delay={String(i * 150)}>
            <p class="cel-quote__text">"{t.quote}"</p>
            <footer class="cel-quote__who">— {t.who}</footer>
          </blockquote>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section style="padding: 80px 32px; text-align: center;">
      <div class="fade-in">
        <h2 class="font-heading" style="font-size: 32px; font-weight: 400; font-style: italic; color: var(--cel-text); margin-bottom: 16px;">Let's talk about your day</h2>
        <p class="font-body" style="font-size: 16px; color: var(--cel-subtle); font-weight: 300; margin-bottom: 28px;">No commitment. Just a conversation.</p>
        <a href="/celebrant/enquire/" class="btn" style="background: var(--cel-accent); color: #FFF;">Enquire Now</a>
      </div>
    </section>

    <CelebrantFooter />
  </main>
</BaseLayout>

<style>
  .cel-hero {
    position: relative;
    overflow: hidden;
    min-height: max(100vh, 650px);
    background: linear-gradient(135deg, #1E3A5F 0%, #2A4F80 40%, #0F2040 100%);
  }

  .cel-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 70%;
  }

  .cel-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(15,25,60,0.05) 0%, rgba(15,25,60,0.55) 100%);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 48px;
  }

  .cel-hero__content {
    text-align: center;
    padding: 32px;
    max-width: 700px;
  }

  .cel-hero__title {
    font-family: 'Source Serif 4', serif;
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 400;
    font-style: italic;
    color: #FFFFFF;
    line-height: 1.1;
    margin-bottom: 0;
  }

  .cel-intro {
    padding: 60px 32px;
    border-bottom: 1px solid color-mix(in srgb, var(--cel-accent) 12%, transparent);
  }

  .cel-intro__content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .cel-intro__desc {
    font-family: 'Source Serif 4', serif;
    font-size: 18px;
    line-height: 1.8;
    color: var(--cel-text);
    font-weight: 300;
    margin-bottom: 36px;
  }

  .cel-intro__actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cel-values {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 40px;
    max-width: 850px;
    margin: 0 auto;
  }

  .cel-values__item {
    text-align: center;
  }

  .cel-values__item h3 {
    font-family: 'Source Serif 4', serif;
    font-size: 18px;
    font-weight: 600;
    font-style: italic;
    color: var(--cel-text);
    margin-bottom: 12px;
  }

  .cel-values__item p {
    font-family: 'Source Serif 4', serif;
    font-size: 14px;
    line-height: 1.7;
    color: var(--cel-subtle);
    font-weight: 300;
  }

  .cel-gallery {
    display: flex;
    gap: 12px;
    max-width: 1000px;
    margin: 0 auto;
    align-items: stretch;
  }

  .cel-gallery__portrait {
    flex: 1;
    border-radius: 6px;
    overflow: hidden;
  }

  .cel-gallery__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cel-gallery__col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cel-gallery__cell {
    flex: 1;
    border-radius: 6px;
    overflow: hidden;
    min-height: 0;
  }

  .cel-gallery__cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cel-testimonials {
    background: color-mix(in srgb, var(--cel-accent) 4%, transparent);
    padding: 70px 32px;
  }

  .cel-quote {
    margin: 0 0 36px;
    padding: 0 0 36px;
    border-bottom: 1px solid color-mix(in srgb, var(--cel-accent) 8%, transparent);
  }

  .cel-quote:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .cel-quote__text {
    font-family: 'Source Serif 4', serif;
    font-size: 19px;
    font-style: italic;
    line-height: 1.7;
    color: var(--cel-text);
    font-weight: 400;
    margin-bottom: 14px;
  }

  .cel-quote__who {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--cel-subtle);
  }

  @media (max-width: 640px) {
    .cel-gallery {
      flex-direction: column;
    }
    .cel-gallery__col {
      flex-direction: row;
    }
  }
</style>
