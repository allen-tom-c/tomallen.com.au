---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Tom Allen — Celebrant. Writer. Grower of things." section="hub">
  <Nav section="hub" hubSubPage="home" />

  <main class="hub-home" style="padding-top: 80px;">
    <!-- Hero -->
    <section class="hub-hero">
      <div class="hub-hero__overlay"></div>
      <div class="hub-hero__content container-full">
        <div class="fade-in">
          <span class="hub-home__label-wrap"><span class="hub-home__label">Darwin, Northern Territory</span></span>
        </div>
        <div class="fade-in" data-delay="150">
          <h1 class="hub-home__title">
            Celebrant. Writer.<br />Grower of things.
          </h1>
        </div>
        <div class="fade-in" data-delay="300">
          <span class="hub-home__intro-wrap"><span class="hub-home__intro">I have a taste for variety: marrying people, starting businesses, farming, writing and mentoring. This site is an opportunity for me to weave all those various threads into one fabric.</span></span>
        </div>
      </div>
    </section>

    <!-- Cards -->
    <section class="container-full" style="padding-top: 60px; padding-bottom: 100px;">
      <div class="hub-home__grid">
        <a href="/celebrant/" class="hub-card hub-card--animate" style="--card-bg: var(--wri-bg); --card-accent: var(--wri-accent); --card-subtle: var(--wri-subtle); --card-text: var(--wri-text); animation-delay: 450ms;">
          <h3 class="hub-card__title font-heading" style="font-style: italic;">Wedding Celebrant</h3>
          <p class="hub-card__desc">I create wedding ceremonies that give pause for reflection, where couples have the chance to express themselves, to reflect on where they've come from and commit to where they're headed.</p>
          <span class="hub-card__link">tomallen.com.au/celebrant →</span>
        </a>

        <a href="/writing/" class="hub-card hub-card--animate" style="--card-bg: var(--wri-bg); --card-accent: var(--wri-accent); --card-subtle: var(--wri-subtle); --card-text: var(--wri-text); animation-delay: 570ms;">
          <h3 class="hub-card__title font-body">Writing</h3>
          <p class="hub-card__desc">Words flow out and I can't stop them. So I organise them in strings and post them on the internet for all to see. Many people have said they enjoy reading what I write, that it helped them think clearly about a subject or created a moment of joy.</p>
          <span class="hub-card__link">Read on Substack →</span>
        </a>

        <a href="/work/" class="hub-card hub-card--animate" style="--card-bg: var(--wri-bg); --card-accent: var(--wri-accent); --card-subtle: var(--wri-subtle); --card-text: var(--wri-text); animation-delay: 690ms;">
          <h3 class="hub-card__title font-ui" style="font-weight: 600;">Enterprise Propagator</h3>
          <p class="hub-card__desc">I have engaged in many varied projects and this is my portfolio: some wrapped up, some ongoing, all opportunities to create businesses and programs that stretched me and hopefully changed the world a little for the better.</p>
          <span class="hub-card__link">See the portfolio →</span>
        </a>

        <a href="/brewing/" class="hub-card hub-card--dashed hub-card--animate" style="--card-bg: var(--wri-bg); --card-accent: var(--wri-accent); --card-subtle: var(--wri-subtle); --card-text: var(--wri-text); animation-delay: 810ms;">
          <h3 class="hub-card__title font-display" style="font-style: italic;">What's Brewing</h3>
          <p class="hub-card__desc">I love collaboration, and all good collaborations start with the dare to dream. So here are some things I'm dreaming about in various states of aliveness. Maybe you'll find something we can work on together.</p>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Hero */
  .hub-hero {
    position: relative;
    height: calc(100vh - 80px);
    min-height: 500px;
    background-image: url('/images/hero-b.jpg');
    background-size: cover;
    background-position: center 35%;
    display: flex;
    align-items: flex-start;
  }

  .hub-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.45) 0%,
      rgba(0, 0, 0, 0.15) 55%,
      rgba(0, 0, 0, 0) 75%
    );
    pointer-events: none;
  }

  .hub-hero__content {
    position: relative;
    z-index: 1;
    padding-top: 60px;
    padding-bottom: 60px;
    width: 100%;
  }

  /* Text */
  .hub-home__title {
    font-family: 'Source Serif 4', serif;
    font-size: clamp(42px, 6vw, 72px);
    font-weight: 300;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 32px;
    max-width: 700px;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.3);
  }

  .hub-home__label-wrap {
    display: block;
    margin-bottom: 24px;
  }

  .hub-home__label {
    display: inline;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(0, 0, 0, 0.48);
    padding: 5px 12px;
    border-radius: 3px;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
  }

  .hub-home__intro-wrap {
    display: block;
    max-width: 560px;
  }

  .hub-home__intro {
    display: inline;
    font-family: 'Source Serif 4', serif;
    font-size: 19px;
    line-height: 2.1;
    color: #fff;
    font-weight: 400;
    background: rgba(0, 0, 0, 0.48);
    padding: 4px 12px;
    border-radius: 3px;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
  }

  /* Cards */
  .hub-home__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  @media (max-width: 560px) {
    .hub-home__grid {
      grid-template-columns: 1fr;
    }
  }

  @keyframes cardFadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hub-card {
    background: var(--card-bg);
    border: 1px solid color-mix(in srgb, var(--card-accent) 12%, transparent);
    border-radius: 10px;
    padding: 40px 32px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .hub-card--animate {
    animation: cardFadeUp 0.7s ease forwards;
    opacity: 0;
  }

  .hub-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px color-mix(in srgb, var(--card-accent) 8%, transparent);
  }

  .hub-card--dashed {
    border-style: dashed;
  }

  .hub-card--dashed:hover {
    border-style: solid;
  }

  .hub-card__title {
    font-family: 'Source Serif 4', serif;
    font-size: 22px;
    font-weight: 400;
    color: var(--card-text);
    margin-bottom: 12px;
  }

  .hub-card__desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    line-height: 1.7;
    color: var(--card-subtle);
    font-weight: 300;
    flex: 1;
  }

  .hub-card__link {
    display: inline-block;
    margin-top: 20px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--card-accent);
    font-weight: 500;
  }
</style>
