---
interface Props {
  activePage?: string;
}

const { activePage = 'home' } = Astro.props;

const links = [
  { href: '/celebrant/', label: 'Home', key: 'home' },
  { href: '/celebrant/pricing/', label: 'Pricing', key: 'pricing' },
  { href: '/celebrant/how-i-work/', label: 'How I Work', key: 'howIWork' },
  { href: '/celebrant/mc-and-ceremonies/', label: 'MC & More', key: 'mcAndCeremonies' },
  { href: '/celebrant/faq/', label: 'FAQ', key: 'faq' },
  { href: '/celebrant/gallery/', label: 'Gallery', key: 'gallery' },
  { href: '/celebrant/about/', label: 'About', key: 'about' },
];
---

<div class="cel-nav" id="cel-nav">
  <div class="cel-nav__inner">
    <span class="cel-nav__title">Tom Allen Celebrant</span>
    <div class="cel-nav__links">
      {links.map((link) => (
        <a href={link.href} class:list={['cel-nav__link', { active: activePage === link.key }]}>{link.label}</a>
      ))}
      <a href="/celebrant/enquire/" class="cel-nav__cta">Enquire</a>
    </div>
    <button class="cel-nav__hamburger" id="cel-hamburger" aria-label="Toggle navigation" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile panel -->
  <div class="cel-nav__mobile-panel" id="cel-mobile-panel">
    {links.map((link) => (
      <a href={link.href} class:list={['cel-nav__mobile-link', { active: activePage === link.key }]}>{link.label}</a>
    ))}
    <a href="/celebrant/enquire/" class="cel-nav__mobile-cta">Enquire</a>
  </div>
</div>

<script>
  const hamburger = document.getElementById('cel-hamburger');
  const nav = document.getElementById('cel-nav');

  hamburger?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('is-open');
    hamburger?.setAttribute('aria-expanded', String(!!isOpen));
  });

  document.addEventListener('click', (e) => {
    if (nav && !nav.contains(e.target as Node)) {
      nav.classList.remove('is-open');
      hamburger?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<style>
  .cel-nav {
    position: fixed;
    top: 40px;
    left: 0;
    right: 0;
    z-index: 190;
    background: rgba(250, 247, 242, 0.96);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(139, 111, 78, 0.08);
  }

  .cel-nav__inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
  }

  .cel-nav__title {
    font-family: 'Source Serif 4', serif;
    font-size: 20px;
    font-weight: 400;
    font-style: italic;
    color: var(--cel-text);
    padding: 14px 0;
  }

  .cel-nav__links {
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .cel-nav__link {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: var(--cel-subtle);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 16px 0;
    border-bottom: 2px solid transparent;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .cel-nav__link:hover { color: var(--cel-accent); }
  .cel-nav__link.active {
    color: var(--cel-accent);
    font-weight: 600;
    border-bottom-color: var(--cel-accent);
  }

  .cel-nav__cta {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--cel-accent);
    color: #FFF;
    padding: 8px 18px;
    border-radius: 3px;
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

  .cel-nav__cta:hover { opacity: 0.9; }

  .cel-nav__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 6px;
    background: none;
    border: none;
    cursor: pointer;
    margin-right: -6px;
  }

  .cel-nav__hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--cel-text);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .cel-nav.is-open .cel-nav__hamburger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .cel-nav.is-open .cel-nav__hamburger span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .cel-nav.is-open .cel-nav__hamburger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile panel */
  .cel-nav__mobile-panel {
    display: none;
    flex-direction: column;
    padding: 8px 32px 16px;
    border-top: 1px solid rgba(219, 39, 119, 0.08);
  }

  .cel-nav__mobile-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--cel-subtle);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 12px 0;
    border-bottom: 1px solid rgba(219, 39, 119, 0.06);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .cel-nav__mobile-link:last-of-type {
    border-bottom: none;
  }

  .cel-nav__mobile-link:hover,
  .cel-nav__mobile-link.active {
    color: var(--cel-accent);
  }

  .cel-nav__mobile-cta {
    display: inline-block;
    margin-top: 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--cel-accent);
    color: #FFF;
    padding: 10px 20px;
    border-radius: 3px;
    text-decoration: none;
    font-weight: 500;
    text-align: center;
  }

  .cel-nav.is-open .cel-nav__mobile-panel {
    display: flex;
  }

  @media (max-width: 768px) {
    .cel-nav__inner { padding: 0 16px; }
    .cel-nav__title { font-size: 16px; }
    .cel-nav__links { gap: 14px; }
    .cel-nav__link { font-size: 11px; padding: 12px 0; }
  }

  @media (max-width: 640px) {
    .cel-nav__links { display: none; }
    .cel-nav__hamburger { display: flex; }
    .cel-nav__mobile-panel { padding: 8px 16px 16px; }
  }

  @media (max-width: 580px) {
    .cel-nav__title { display: none; }
  }
</style>
