<div class="cel-footer">
  <div class="cel-footer__banner">
    <div class="cel-footer__col">
      <p class="cel-footer__label">Location</p>
      <p class="cel-footer__text">I'm now based in Darwin, NT! I'm willing to travel though, and often have places I can stay, so reach out and let's discuss your wedding plans.</p>
    </div>

    <div class="cel-footer__col cel-footer__col--center">
      <img src="/images/celebrant/ally.webp" alt="LGBTQ+ Ally" class="cel-footer__ally" />
    </div>

    <div class="cel-footer__col cel-footer__col--right">
      <p class="cel-footer__label">Get in touch</p>
      <a href="tel:0421102154" class="cel-footer__contact-link">0421 102 154</a>
      <a href="mailto:allen.tom.c@gmail.com" class="cel-footer__contact-link">allen.tom.c@gmail.com</a>
    </div>
  </div>

  <p class="cel-footer__links">
    Tom Allen is also a
    <a href="/writing/">writer</a>,
    <a href="/work/">enterprise builder</a>, and
    <a href="/brewing/">maker of things</a>.
  </p>
</div>

<style>
  .cel-footer {
    border-top: 1px solid rgba(139, 111, 78, 0.12);
    margin-top: 40px;
  }

  .cel-footer__banner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 32px;
    align-items: center;
    padding: 36px 48px;
    background: color-mix(in srgb, var(--cel-accent) 4%, transparent);
  }

  .cel-footer__col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cel-footer__col--center {
    align-items: center;
    justify-content: center;
  }

  .cel-footer__col--right {
    align-items: flex-end;
  }

  .cel-footer__label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cel-accent);
    margin-bottom: 4px;
  }

  .cel-footer__text {
    font-family: 'Source Serif 4', serif;
    font-size: 13px;
    line-height: 1.7;
    color: var(--cel-text);
    font-weight: 300;
    max-width: 260px;
  }

  .cel-footer__ally {
    width: auto;
    height: 80px;
    border-radius: 4px;
  }

  .cel-footer__contact-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--cel-text);
    text-decoration: none;
  }

  .cel-footer__contact-link:hover {
    color: var(--cel-accent);
  }

  .cel-footer__links {
    padding: 20px 48px;
    text-align: center;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--cel-subtle);
    font-weight: 300;
  }

  .cel-footer__links a {
    color: var(--cel-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .cel-footer__links a:hover {
    opacity: 0.8;
  }

  @media (max-width: 640px) {
    .cel-footer__banner {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 32px 24px;
      gap: 24px;
    }
    .cel-footer__col--center,
    .cel-footer__col--right {
      align-items: center;
    }
    .cel-footer__text {
      max-width: 100%;
    }
    .cel-footer__links {
      padding: 20px 24px;
    }
  }
</style>
